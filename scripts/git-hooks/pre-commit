#!/bin/sh
# Block commits that include an uncommented \includeonly in thesis.tex.
# \includeonly is a drafting toggle; committing it means future builds
# silently typeset only a subset of chapters.

set -e

if ! git diff --cached --name-only --diff-filter=ACMR | grep -qx 'thesis.tex'; then
    exit 0
fi

# Check the staged version (not the worktree), so `git add -p` partial stages
# are evaluated correctly.
staged=$(git show :thesis.tex)

fail=0
if echo "$staged" | grep -nE '^[[:space:]]*\\includeonly' >&2; then
    echo "pre-commit: thesis.tex has an uncommented \\includeonly (see line above)." >&2
    fail=1
fi
if echo "$staged" | grep -nE '^[[:space:]]*\\documentclass\[[^]]*\bdraft\b[^]]*\]' >&2; then
    echo "pre-commit: thesis.tex has 'draft' in \\documentclass options (see line above)." >&2
    fail=1
fi

if [ "$fail" -ne 0 ]; then
    echo "" >&2
    echo "  Drop the drafting toggle(s) before committing, or use 'git commit --no-verify' to override." >&2
    exit 1
fi
