\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{thesis-style}[2026/05/27 Luca Arnaboldi thesis style]

% --- Print variant -------------------------------------------------------
% thesis-print.tex sets \ThesisPrintVariant before \input{thesis.tex}. This
% package is the ONLY place in the build that branches on it: everything else
% -- thesis.tex, the chapters, the papers -- is shared verbatim between the
% digital and the printable PDF. Three things change, each marked \ifpc@print or
% \pc@printalt below: hyperref coloring, \href, and \cvpersonal. Colors that
% carry information (figures, the TikZ palette, color-keyed legend words) are
% deliberately left alone -- blacking them out would unhook the legends.
%
% Deliberately NOT changed: the page geometry. A geometry bindingoffset was
% tried and dropped -- see the margin-note budget below for why.
\newif\ifpc@print
\ifdefined\ThesisPrintVariant \pc@printtrue \fi

% \pc@printalt{print version}{digital version} -- expands to exactly one of its
% two arguments, leaving no \if/\fi tokens behind. Needed where a bare
% conditional is unsafe, e.g. at the start of a tabular cell (\cvpersonal),
% which TeX expands while looking ahead for \omit.
\newcommand{\pc@printalt}{%
  \ifpc@print\expandafter\@firstoftwo\else\expandafter\@secondoftwo\fi}

% Options for packages that papers-dependencies.tex loads bare.
% This .sty MUST be loaded before \input{papers-dependencies.tex}.
% Print: hidelinks keeps the PDF links (working ToC/bookmarks on screen) but
% renders them with no color and no border, i.e. invisible on paper.
\ifpc@print
  \PassOptionsToPackage{hidelinks,bookmarks}{hyperref}
\else
  \PassOptionsToPackage{%
    colorlinks,linkcolor=blue,urlcolor=magenta,citecolor=green,bookmarks%
  }{hyperref}
\fi
\PassOptionsToPackage{section}{placeins}

% Packages that papers-dependencies.tex deliberately skips.
\RequirePackage[%
  paper=a4paper,%
  textwidth=140mm,%
  textheight=210mm,%
  marginratio={4:6,5:5}%
]{geometry}

% --- Revision-addendum margin notes -------------------------------------
% Permanent outer-margin addenda added during revision (extra context, or
% developments after the paper was published). A small star marks the point
% in the text and heads the note. Non-floating -> robust in the math/float-
% dense paper chapters.

% Margin budget: outer margin = A4 210mm - textwidth 140mm = 70mm, split
% 28:42 (inner:outer) by marginratio 4:6.  32mm + 5mm sep = 37mm, inside the
% 42mm outer margin with a 5mm safety strip to the page edge.
%
% This budget is why the print variant carries NO geometry bindingoffset. On
% fixed A4 with a fixed 140mm measure the two margins always sum to 70mm, so a
% gutter at the spine can only be funded out of the outer margin -- and this
% note block already claims 37 of its 42mm. A 5mm bindingoffset makes geometry
% re-split the remaining 65mm as 26:39, leaving the notes a 2mm strip to the
% page edge, inside the non-printable border of a typical office printer.
% Shrinking \marginparwidth to buy it back would reflow every note and
% invalidate the hand-tuned \addnote[nudge] offsets; shrinking \textwidth would
% reflow the whole thesis. 28mm at the spine is generous enough for a ~270-page
% block on its own, so the print variant keeps the digital geometry exactly.
\setlength{\marginparwidth}{32mm}
\setlength{\marginparsep}{5mm}

% xcolor + ragged2e needed here; papers-dependencies.tex loads xcolor only
% later (~line 143) and never loads ragged2e. Double-loading xcolor is a no-op.
\RequirePackage{xcolor}
\RequirePackage{ragged2e}
\RequirePackage{marginnote}   % non-floating \marginnote

\definecolor{addnotegray}{gray}{0.30}   % muted near-black

% Shared margin-note body formatting.
\newcommand{\pc@addnotebody}[1]{%
  \scriptsize\color{addnotegray}%
  \setlength{\parindent}{0pt}\RaggedRight
  #1\par}

% \addnote[<vertical nudge>]{text}
%   Drops the note in the outer margin, aligned with the call site.
%   The optional nudge (default 0pt) dodges a rare collision, e.g. \addnote[14pt]{...}.
\newcommand{\addnote}[2][0pt]{%
  \leavevmode
  \marginnote{\pc@addnotebody{#2}}[#1]}

% addnotelong — same, as an environment for long / multi-paragraph notes.
\newsavebox{\pc@addnotesave}
\newenvironment{addnotelong}
  {\leavevmode
   \begin{lrbox}{\pc@addnotesave}%
   \begin{minipage}{\marginparwidth}%
     \scriptsize\color{addnotegray}%
     \setlength{\parindent}{0pt}\RaggedRight
     \ignorespaces}
  {\end{minipage}\end{lrbox}%
   \marginnote{\usebox{\pc@addnotesave}}}
% ------------------------------------------------------------------------

\RequirePackage[indent=0cm]{parskip}

% \begin{noparskip} ... \end{noparskip}
%   Suppresses \parskip between paragraphs for a block of text (e.g. a
%   front-matter abstract), without leaking the change past \end{noparskip}
%   -- \begin/\end already group, so no explicit \begingroup/\endgroup needed.
\newenvironment{noparskip}{\setlength{\parskip}{0pt}}{}

% EB Garamond as the main text font. Ships with TeX Live, so no
% system/CI font conditional is needed. Falls back silently if the
% font is somehow missing.
% \setmainfont is deferred to \AtEndPreamble so it runs after T1 fontenc
% (loaded later by papers-dependencies.tex) — otherwise fontenc would
% re-bind rmfamily to T1 ec-fonts and leak ec-rm into the bibliography.
\RequirePackage{etoolbox}
\RequirePackage{fontspec}
\AtEndPreamble{%
  \IfFontExistsTF{EB Garamond}{%
    \setmainfont{EB Garamond}%
  }{}%
}

% --- Print variant: spell out external URLs -----------------------------
% On paper an \href is a dead phrase -- "our GitHub repository" with the
% address nowhere on the page. In the print variant the link text stays put
% and the bare URL follows as a footnote. Deferred to \AtEndPreamble because
% hyperref defines \href and is loaded later, by papers-dependencies.tex.
% The four \href calls in \cvpersonal sit inside a tabular, where \footnote is
% swallowed; they are handled separately at the bottom of this file.
\ifpc@print
  \AtEndPreamble{%
    % hyperref's signature is \href[options]{url}{text}; the optional argument
    % is kept so a future \href[...] call site doesn't silently break.
    \renewcommand{\href}[3][]{#3\footnote{\url{#2}}}%
  }
\fi

% --- Figure palette + TikZ libraries ------------------------------------
% Shared by the hand-drawn schematics under chapters/figs/ (e.g. the
% teacher--student network diagram in the introduction). The colours need
% only xcolor (required above). The TikZ library loads must wait until tikz
% itself is pulled in by papers-dependencies.tex -- which is \input AFTER this
% package -- so they are deferred to \AtEndPreamble (etoolbox, required above),
% which still fires inside the preamble but after tikz has loaded.
\definecolor{netin}{HTML}{5B6B7B}   % input layer      -- slate
\definecolor{nethid}{HTML}{4F86C6}  % hidden neuron 1  -- blue
\definecolor{nethidb}{HTML}{2E9E8F} % hidden neuron 2  -- teal
\definecolor{nethidc}{HTML}{8E6FC6} % hidden neuron p  -- violet
\definecolor{netout}{HTML}{E0922F}  % output layer     -- amber
\AtEndPreamble{\usetikzlibrary{arrows.meta,positioning,calc}}

% \catchy / \descr — title-part markers, only meaningful inside a \paperchapter
% title. Default to identity so a title without markers still works.
\newcommand{\catchy}[1]{#1}
\newcommand{\descr}[1]{#1}

% Sentinel meaning "no explicit running-header was given to \paperchapter".
\newcommand{\pc@usecatchy}{}

% \paperchapter[running-header]{title}{authors}{abstract-input-path}
%   The title is ONE string in natural reading order. Wrap the catchy part in
%   \catchy{...} and the rest -- INCLUDING the joining colon/space -- in
%   \descr{...}; on the title page \catchy stays bold and \descr is medium (not
%   bold), running together at the chapter size (use \\ for a line break).
%   The ToC + PDF bookmark always get the FULL title. The running header is, in
%   order of preference: the optional [running-header] if given; otherwise the
%   \catchy part only (markers gobbled). A title with no markers and no optional
%   renders exactly as before. Then italic authors + small indented abstract.
\newcommand{\paperchapter}[4][\pc@usecatchy]{%
  % Full plain title (ToC/bookmark) + catchy-only fallback header. \\ collapses
  % to a space here so a title-page line break never leaks into ToC/header.
  \begingroup
    \renewcommand{\catchy}[1]{##1}%
    \renewcommand{\descr}[1]{##1}%
    \let\\\space
    \protected@xdef\pc@toctitle{#2}%      full title, both parts
    \renewcommand{\descr}[1]{}%
    \protected@xdef\pc@catchyonly{#2}%    catchy part only
  \endgroup
  % Running header: explicit optional wins, else the catchy-only fallback.
  \def\pc@tmp{#1}\def\pc@tmpdef{\pc@usecatchy}%
  \ifx\pc@tmp\pc@tmpdef
    \let\@chaptermark\pc@catchyonly
  \else
    \def\@chaptermark{#1}%
  \fi
  % Title-page meanings: catchy keeps inherited \bfseries, descr goes medium,
  % \\ is a real line break. Render via the ORIGINAL \@chapter so the ToC gets
  % the plain title while the heading keeps the marked-up styling; the running
  % header is supplied through \@chaptermark (see \pc@installmarks below).
  \renewcommand{\catchy}[1]{##1}%
  \renewcommand{\descr}[1]{{\mdseries ##1}}%
  \let\pc@kept@chapter\@chapter
  \let\@chapter\old@chapter
  \chapter[\pc@toctitle]{#2}%
  \let\@chapter\pc@kept@chapter
  \renewcommand{\catchy}[1]{##1}%
  \renewcommand{\descr}[1]{##1}%
  \begin{center}\itshape #3\end{center}%
  \begingroup
    \small
    \begin{quote}
      \noindent\textsc{Abstract.}\enspace\input{#4}%
    \end{quote}
  \endgroup
  \par\vspace{0.5\baselineskip}%
}

% --- Decoupled ToC vs. running header for \chapter / \section / \subsection ---
% An optional [..] argument to a sectioning command feeds ONLY the running
% header (its \xxxmark); the ToC and PDF bookmark always use the full mandatory
% title. With no optional argument, behaviour is unchanged (header = title).
% Mechanism: stash the optional arg in \@<type>mark, have each \xxxmark read its
% stash, and hand the full title to the original \@chapter/\@sect for both the
% ToC and the (now ignored) mark argument. Must run AFTER hyperref/nameref wrap
% \@chapter/\@sect, hence \AtEndPreamble. \paperchapter sets \@chaptermark
% itself and renders through \old@chapter (see above).
\def\pc@installmarks{%
  \providecommand{\chaptermark}[1]{}%
  \providecommand{\sectionmark}[1]{}%
  \providecommand{\subsectionmark}[1]{}%
  \def\@chaptermark{}%
  \def\@sectionmark{}%
  \def\@subsectionmark{}%
  \let\pc@oldchaptermark\chaptermark
  \let\pc@oldsectionmark\sectionmark
  \let\pc@oldsubsectionmark\subsectionmark
  \def\chaptermark##1{\pc@oldchaptermark{\@chaptermark}}%
  \def\sectionmark##1{\pc@oldsectionmark{\@sectionmark}}%
  \def\subsectionmark##1{\pc@oldsubsectionmark{\@subsectionmark}}%
  \let\old@chapter\@chapter
  \def\@chapter[##1]##2{\def\@chaptermark{##1}\old@chapter[{##2}]{##2}}%
  \let\old@sect\@sect
  \def\@sect##1##2##3##4##5##6[##7]##8{%
    \@namedef{@##1mark}{##7}%
    \old@sect{##1}{##2}{##3}{##4}{##5}{##6}[{##8}]{##8}%
  }%
}
\AtEndPreamble{\pc@installmarks}

% --- Theorem-like environments ------------------------------------------
\RequirePackage{amsthm}
\newtheorem{example}{Example}[chapter]

% --- Numbered publication list (foreword) --------------------------------
% \begin{contribution}{title}{authors}{venue} abstract text \end{contribution}
% Uses a single global counter across the whole document.
\newcounter{contribution}
\newenvironment{contribution}[4]{%
  % #1=title  #2=authors  #3=venue  #4=abstract (e.g. \input{...})
  \refstepcounter{contribution}%
  \par\medskip
  \noindent\textbf{\arabic{contribution}.}\enspace\textbf{#1}\newline
  {\small\itshape #2}\newline
  {\small\itshape #3}%
  {\setlength{\parskip}{0pt}\par}%
  \begingroup\small\setlength{\parindent}{0pt}\setlength{\leftskip}{1.5em}%
  \noindent\textsc{Abstract.}\enspace #4\par
  \endgroup
  {\setlength{\parskip}{0pt}\par}%
  \begingroup\small\setlength{\parindent}{0pt}\setlength{\leftskip}{1.5em}%
  \noindent\textsc{Contribution.}\enspace\ignorespaces
}{%
  \par\endgroup
}

% --- Curriculum Vitae formatting -----------------------------------------
% Tight vertical rhythm throughout by design -- entries sit close together,
% only the one identifying label per line is bold, nothing is italicized.

% \cvsection{title} -- heading with a thin rule, used inside the unnumbered
% CV chapter (front-matter/cv.tex).
\newcommand{\cvsection}[1]{%
  \par\medskip\noindent{\Large\bfseries #1}\par
  \vspace{-0.35em}\noindent\rule{\linewidth}{0.4pt}\par\smallskip}

% \cv@entrysep -- vertical gap after each \cventry; default matches the
% Education/Experience spacing. \begin{cvcompact}...\end{cvcompact} below
% overrides it locally for denser fact-list sections.
\newlength{\cv@entrysep}
\setlength{\cv@entrysep}{2pt}

% \cventry{title}{entity}{location}{date}{extra}
%   Uniform two-line entry -- the same structure for every entry in the CV
%   (Education, Experience, Awards, Scientific Reviewing, Teaching,
%   Open Source, and, via \cvtravel below, Conferences):
%     line 1: bold "title @ entity" (just "title" if entity is empty)
%             ....(fill)....  date
%     line 2: extra, if given  ....(fill)....  location
%             (line 2 is omitted entirely if both extra and location are
%             empty, so a bare fact with no sub-detail doesn't leave a
%             half-blank second line)
%   #2 (entity), #3 (location), #4 (date) and #5 (extra) may be empty.
%   Empty-argument tests use etoolbox's \ifstrempty (robust to any content,
%   including a leading "[") rather than a hand-rolled \ifx sentinel trick.
%   Note the \\{} (not bare \\) before line 2: if the following text starts
%   with "[" (as the Teaching placeholder's "[Institution]" example does), a
%   bare \\ would misparse it as \\'s optional vertical-skip argument
%   ("Missing number, treated as zero."); the empty group blocks that
%   lookahead.
%   Uses \hspace* (not \hspace) for the fill glue: when #5 is empty, line 2
%   starts with nothing but that glue, and plain \hspace glue at the very
%   start of a line gets silently discarded by TeX's line breaker -- it
%   never gets to push #3 to the right, leaving the location stuck on the
%   left. The starred form is unskippable, so it survives being first.
\newcommand{\cventry}[5]{%
  \par\noindent\textbf{#1\ifstrempty{#2}{}{\ @\ #2}}\hspace*{0.5em plus 1fill}\mbox{#4}%
  \ifstrempty{#5}{%
    \ifstrempty{#3}{}{\\{}\hspace*{0.5em plus 1fill}\mbox{#3}}%
  }{%
    \\{}#5\hspace*{0.5em plus 1fill}\mbox{#3}%
  }%
  \par\vspace{\cv@entrysep}}

% \cvline{title}{description}{date} -- simple single-line entry, no
% location: bold title, optional ": description", date filled right.
% #2 and #3 may be empty. For facts with just one identifying label plus
% an optional detail and a timeframe -- no separate place involved.
% Used for Scientific Reviewing, Teaching, Open Source.
\newcommand{\cvline}[3]{%
  \par\noindent\textbf{#1}\ifstrempty{#2}{}{: #2}\hspace*{0.5em plus 1fill}\mbox{#3}%
  \par\vspace{\cv@entrysep}}

% \begin{cvcompact}...\end{cvcompact} -- denser \cventry/\cvtravel/\cvline
% spacing for fact-list sections (Awards, Conferences, Scientific Reviewing,
% Teaching, Open Source) vs. the default used by Education/Experience.
% Zeroes \parskip (the between-paragraph gap every \cventry rides on) and
% replaces it with a small, explicit \cv@entrysep -- an environment group,
% so both revert automatically at \end{cvcompact}.
\newenvironment{cvcompact}{%
  \setlength{\parskip}{0pt}%
  \setlength{\cv@entrysep}{4pt}%
}{}

% \cvtravel{event}{location}{date}{contribution type} -- conference/school/
% workshop entry. Thin wrapper around \cventry: the event is the plain bold
% title (no "@ entity" join here), date fills line 1; the contribution type
% is the line-2 extra, location fills line 2. Contribution type empty falls
% back to a literal "-". The fallback is resolved into a plain macro first
% (rather than embedding an empty-test inside the argument being
% constructed for \cventry) since \ifstrempty itself needs its argument
% already fully formed.
\newcommand{\cvtravel}[4]{%
  \def\pc@cvtravelrole{#4}%
  \ifx\pc@cvtravelrole\@empty\def\pc@cvtravelrole{-}\fi
  \cventry{#1}{}{#2}{#3}{\pc@cvtravelrole}}

% \begin{cvpublist}...\end{cvpublist} -- tight numbered list for publications.
\newenvironment{cvpublist}{%
  \begin{enumerate}[label=\arabic*.,leftmargin=1.6em,itemsep=3pt,parsep=0pt,topsep=3pt]}{%
  \end{enumerate}}

% \cvpub{authors}{title}{venue}{year} -- one numbered publication entry;
% use inside cvpublist. Title is bold (the highlighted element); authors
% and venue are plain -- no italics.
\newcommand{\cvpub}[4]{\item \textbf{#2} #1. #3, #4.}

% \cvpersonal{name}{location}{email}{website}{scholar-url}{github-user}
%   Labeled two-column Personal Information table (Luca's preferred version
%   over the earlier flowing-text block). Deliberately not a full multi-line
%   postal address.
%   Print variant: these four \href calls are the one place the global
%   "footnote the URL" rule above cannot reach -- \footnote inside a tabular is
%   swallowed -- so each row is branched by hand instead. Three of them already
%   read as their own address; only Google Scholar hid behind "Profile" and so
%   gains the literal URL, set \small because the l column does not wrap and the
%   50-character address is borderline against the 140mm text width.
\newcommand{\cvpersonal}[6]{%
  \par\noindent
  \begin{tabular}{@{}ll@{}}
    Name           & #1 \\
    Location       & #2 \\
    Email          & \pc@printalt{#3}{\href{mailto:#3}{#3}} \\
    Website        & \pc@printalt{#4}{\href{https://#4}{#4}} \\
    Google Scholar & \pc@printalt{{\small\url{#5}}}{\href{#5}{Profile}} \\
    GitHub         & \pc@printalt{github.com/#6}{\href{https://github.com/#6}{#6}} \\
  \end{tabular}\par}

\endinput
